{
    "name": "aistea/aisteablog",
    "type": "typo3-cms-extension",
    "description": "Slim blog extension for aistea.me portfolio",
    "homepage": "https://aistea.me",
    "license": ["GPL-2.0-or-later"],
    "keywords": ["TYPO3 CMS", "blog"],
    "require": {
        "typo3/cms-core": "^14.0",
        "typo3/cms-extbase": "^14.0",
        "typo3/cms-fluid": "^14.0",
        "typo3/cms-frontend": "^14.0"
    },
    "autoload": {
        "psr-4": {
            "Aistea\\Aisteablog\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "aisteablog"
        }
    }
}
